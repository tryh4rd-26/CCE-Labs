<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvExplorerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Course Explorer"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"/>

                <Button
                    android:id="@+id/btnRegFromExplorer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registration"
                    android:textSize="10sp"
                    android:layout_alignParentRight="true"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available Courses (ListView)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <ListView
                android:id="@+id/lvCourses"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campus Facilities (GridView)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <GridView
                android:id="@+id/gvFacilities"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:numColumns="2"
                android:verticalSpacing="10dp"
                android:horizontalSpacing="10dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weekly Timetable (TableLayout)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                android:background="#000000"
                android:padding="1dp">

                <TableRow android:background="#FFFFFF">
                    <TextView android:text="Day" android:textStyle="bold" android:padding="8dp"/>
                    <TextView android:text="Course" android:textStyle="bold" android:padding="8dp"/>
                    <TextView android:text="Room" android:textStyle="bold" android:padding="8dp"/>
                </TableRow>

                <TableRow android:background="#FFFFFF" android:layout_marginTop="1dp">
                    <TextView android:text="Monday" android:padding="8dp"/>
                    <TextView android:text="Android" android:padding="8dp"/>
                    <TextView android:text="AB5" android:padding="8dp"/>
                </TableRow>

                <TableRow android:background="#FFFFFF" android:layout_marginTop="1dp">
                    <TextView android:text="Tuesday" android:padding="8dp"/>
                    <TextView android:text="ML" android:padding="8dp"/>
                    <TextView android:text="AB2" android:padding="8dp"/>
                </TableRow>

                <TableRow android:background="#FFFFFF" android:layout_marginTop="1dp">
                    <TextView android:text="Wednesday" android:padding="8dp"/>
                    <TextView android:text="OS" android:padding="8dp"/>
                    <TextView android:text="AB1" android:padding="8dp"/>
                </TableRow>
            </TableLayout>

            <Button
                android:id="@+id/btnMoreActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="More Actions (Popup Menu)"
                android:layout_marginTop="24dp"/>

            <Button
                android:id="@+id/btnGoToDB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Go to Database Manager"
                android:layout_marginTop="8dp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>